# clip-report MCP — DB 접속정보 (사내 전용). 이 파일을 .env 로 복사해 값을 채우세요.
# 서버(CrfMcpServer)가 아래 위치를 순서대로 자동 로드합니다(내장):
#   1) 환경변수 CLIP_ENV_FILE 가 가리키는 파일
#   2) ~/clip-report-mcp/.env
#   3) ~/.dbtools/.env
#   4) ./.env  (서버 실행 작업폴더)
# 또는 동명의 환경변수(CLIP_DB_URL/USER/PWD)가 있으면 그게 우선.

CLIP_DB_URL=jdbc:tibero:thin:@<host>:<port>:<sid>
CLIP_DB_USER=<DB_USER>
CLIP_DB_PWD=<DB_PASSWORD>
